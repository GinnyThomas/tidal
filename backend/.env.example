# .env.example
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it contains secrets.
# This file (.env.example) is safe to commit — it has no real values.
#
# Usage:
#   cp .env.example .env
#   # then edit .env with your actual values

# --- Database ---
# Full PostgreSQL connection string.
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=postgresql://tidal_user:your_password_here@localhost:5432/tidal

# --- Security ---
# Secret key used to sign JWT tokens. Must be long, random, and private.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-long-random-string

# JWT algorithm — HS256 is the standard symmetric signing algorithm.
# You almost certainly do not need to change this.
ALGORITHM=HS256

# How many minutes a JWT access token remains valid.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Application ---
APP_NAME=Tidal
